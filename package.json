{
    "name": "eslint-plugin-angular",
    "version": "5.0.0",
    "description": "ESLint rules for AngularJS projects",
    "main": "index.js",
    "packageManager": "pnpm@11.12.0",
    "scripts": {
        "lint": "oxlint",
        "test:run": "vitest run --coverage",
        "generate:docs": "node scripts/docs.js",
        "test": "pnpm lint && pnpm generate:docs && pnpm test:run"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Gillespie59/eslint-plugin-angularjs.git"
    },
    "contributors": [
        "Emmanuel Demey (http://gillespie59.github.io/)",
        "Tilman Potthof (https://github.com/tilmanpotthof)",
        "Remco Haszing (https://github.com/remcohaszing)"
    ],
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/Gillespie59/eslint-plugin-angularjs/issues"
    },
    "homepage": "https://github.com/Gillespie59/eslint-plugin-angularjs",
    "devDependencies": {
        "@vitest/coverage-v8": "^4.1.10",
        "chai": "5.3.3",
        "chai-spies": "1.1.0",
        "eslint": "^10.7.0",
        "espree": "10.4.0",
        "lodash": "4.18.1",
        "oxlint": "^1.73.0",
        "parse-comments": "0.4.3",
        "vitest": "^4.1.10"
    },
    "peerDependencies": {
        "eslint": "^9.32.0 || ^10.0.0"
    },
    "keywords": [
        "eslint",
        "eslintplugin",
        "angularjs"
    ]
}
